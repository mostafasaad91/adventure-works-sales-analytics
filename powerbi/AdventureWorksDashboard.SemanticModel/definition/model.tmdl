model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["FactSales","DimDate","DimProduct","DimCustomer","DimTerritory","DimSalesPerson","DimOrderType","DimOffer","DeadStock","QuotaAttainment","RepeatPurchaseSegments","RepeatPurchaseStats","CohortRetentionSummary","BasketAffinity"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

ref table DimCustomer
ref table DimDate
ref table DimProduct
ref table DimSalesPerson
ref table DimTerritory
ref table FactSales
ref table _Measures
ref table DimOrderType
ref table DimOffer
ref table DeadStock
ref table QuotaAttainment
ref table RepeatPurchaseSegments
ref table RepeatPurchaseStats
ref table CohortRetentionSummary
ref table BasketAffinity

