model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	discourageImplicitMeasures
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["FactSales","DimDate","DimProduct","DimCustomer","DimTerritory","DimSalesPerson"]

annotation __PBI_TimeIntelligenceEnabled = 0

annotation PBI_ProTooling = ["DevMode"]

ref table DimCustomer
ref table DimDate
ref table DimProduct
ref table DimSalesPerson
ref table DimTerritory
ref table FactSales
ref table _Measures

